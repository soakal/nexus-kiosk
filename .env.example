# Nexus Kiosk Configuration
# See docs/azure-for-it-admin.md for Azure setup instructions

# Server port
PORT=3001

# Environment mode
NODE_ENV=production

# Allowed CORS origin. REQUIRED in production (the server refuses to start
# without it and never falls back to '*'). The client is served same-origin,
# so set this to the kiosk's own URL, e.g. http://localhost:3001 or the host
# the dashboard is reached at. Leave blank only for non-production/dev.
CORS_ORIGIN=http://localhost:3001

# Azure App Registration (get from IT admin)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=

# Encryption secret (auto-generated by installer, or set manually)
ENCRYPTION_SECRET=

# Logging level (debug, info, warn, error)
LOG_LEVEL=info

# Test mode: disable Azure auth, use mock data (set to 'true' to enable)
DISABLE_AZURE=false
